MAC_RELEASE_APP_NAME=BlackBar
MAC_RELEASE_REPO=steipete/BlackBar
MAC_RELEASE_BUNDLE_ID=com.steipete.blackbar
MAC_RELEASE_VERSION_FILE=version.env
MAC_RELEASE_APPCAST=appcast.xml
MAC_RELEASE_INFO_PLIST=Resources/Info.plist

MAC_RELEASE_APP_ZIP='BlackBar-${MARKETING_VERSION}.zip'
MAC_RELEASE_DSYM_ZIP='BlackBar-${MARKETING_VERSION}.dSYM.zip'
MAC_RELEASE_ARTIFACT_PREFIX='BlackBar-'
MAC_RELEASE_FEED_URL='https://raw.githubusercontent.com/steipete/BlackBar/main/appcast.xml'
MAC_RELEASE_DOWNLOAD_URL_PREFIX='https://github.com/steipete/BlackBar/releases/download/v${MARKETING_VERSION}/'

MAC_RELEASE_PRECHECK='swift test'
MAC_RELEASE_PACKAGE_CMD='Scripts/sign-and-notarize.sh'
MAC_RELEASE_TAG_SIGNED=0
MAC_RELEASE_TAG_FORCE=1
MAC_RELEASE_GENERATE_APPCAST_ARGS='--maximum-deltas 0'
